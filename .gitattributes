# Normalise line endings — A.1 forces LF on source (risk item).
* text=auto eol=lf

*.py    text eol=lf
*.pyi   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.vue   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.hcl   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sql   text eol=lf
*.html  text eol=lf
*.css   text eol=lf

*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary — never normalise
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.drawio binary
