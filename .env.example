# SMAP environment template. Copy to `.env` and edit for local dev.
# In production, secrets (JWT keys, DB password, etc.) come from Vault KV —
# only `SMAP_VAULT_ROLE_ID` / `SMAP_VAULT_SECRET_ID` live in env.

# ---------- app ----------
SMAP_APP_ENV=dev
SMAP_APP_VERSION=0.0.0
SMAP_APP_DOCS_ENABLED=true

# ---------- database ----------
SMAP_DB_DSN=postgresql+asyncpg://smap:smap@postgres:5432/smap
SMAP_DB_POOL_SIZE=20
SMAP_DB_MAX_OVERFLOW=10
SMAP_DB_STATEMENT_TIMEOUT_MS=30000

# ---------- redis ----------
SMAP_REDIS_DSN=redis://redis:6379/0

# ---------- qdrant ----------
SMAP_QDRANT_URL=http://qdrant:6333

# ---------- neo4j ----------
SMAP_NEO4J_URL=bolt://neo4j:7687
SMAP_NEO4J_USER=neo4j
SMAP_NEO4J_PASSWORD=neo4jneo4j
SMAP_NEO4J_DATABASE=smap

# ---------- minio ----------
SMAP_MINIO_ENDPOINT=minio:9000
SMAP_MINIO_ACCESS_KEY=minioadmin
SMAP_MINIO_SECRET_KEY=minioadmin
SMAP_MINIO_USE_TLS=false
# The following three are fixed and MUST match REQUIREMENTS.md §21.5.
SMAP_MINIO_BUCKET_CHAT_UPLOADS=chat-uploads
SMAP_MINIO_BUCKET_RAG_SOURCES=rag-sources
SMAP_MINIO_BUCKET_EXPORTS=exports

# ---------- vault ----------
SMAP_VAULT_ADDR=http://vault:8200
SMAP_VAULT_DEV_TOKEN=root
# In prod, leave DEV_TOKEN empty and set:
# SMAP_VAULT_ROLE_ID=
# SMAP_VAULT_SECRET_ID=
SMAP_VAULT_TRANSIT_KEY_PROVIDER=smap-provider-secret
SMAP_VAULT_TRANSIT_KEY_GUEST=smap-guest-link
SMAP_VAULT_TRANSIT_KEY_JWT=smap-jwt-sign
SMAP_VAULT_KV_MOUNT=secret
SMAP_VAULT_KV_PREFIX=smap/config

# Vault KV layout — `smap.bootstrap vault-init` provisions these paths under
# {SMAP_VAULT_KV_MOUNT}/{SMAP_VAULT_KV_PREFIX}/. The backend reads them at
# startup; missing keys yield a ConfigError. Required structure:
#
#   secret/smap/config/hmac-key            { key: <base64 32-byte>, version: <int>=1 }
#       used by envelope HMAC (R7.06); rotated by `smap.rotation` (D.10).
#   secret/smap/config/minio               { access_key, secret_key, bucket_*: ... }
#       runtime MinIO service-account creds; root creds in env are bootstrap-only.
#   secret/smap/config/neo4j               { password }
#   secret/smap/config/database            { password }
#   secret/smap/config/redis               { password }   (optional)
#   secret/smap/config/qdrant              { api_key }    (optional, prod only)
#
# Transit keys (separate Vault transit engine, NOT KV):
#   transit/keys/smap-provider-secret      AES-256-GCM, envelope wrap (§7.6)
#   transit/keys/smap-guest-link           ed25519, guest-link signing
#   transit/keys/smap-jwt-sign             RSA-2048, JWT RS256 signing (R6.03)

# ---------- egress proxy ----------
# HMAC-SHA256 key shared between the egress proxy and MCP sandbox containers.
# Required for the egress-proxy service to start. Generate with:
#   openssl rand -hex 32
EGRESS_PROXY_SHARED_SECRET=

# ---------- security ----------
# Comma list is parsed by pydantic-settings into list[str].
SMAP_SEC_TRUSTED_PROXIES=["127.0.0.1/32","::1/128"]
SMAP_SEC_CSP_REPORT_ONLY=false
SMAP_SEC_CORS_ORIGINS=[]
SMAP_SEC_SESSION_COOKIE_NAME=smap_session
SMAP_SEC_SESSION_COOKIE_SECURE=false
SMAP_SEC_SESSION_COOKIE_SAMESITE=lax

# ---------- logging ----------
SMAP_LOG_LEVEL=info
SMAP_LOG_SERVICE_NAME=smap-backend
SMAP_LOG_JSON=true

# ---------- limits (R19.02) ----------
SMAP_LIMIT_AUTH_PER_MIN_IP=10
SMAP_LIMIT_CHAT_PER_MIN_USER=60
SMAP_LIMIT_UPLOAD_PER_MIN_USER=10
SMAP_LIMIT_OTHER_PER_MIN_USER=300
SMAP_LIMIT_WS_CONCURRENT_PER_USER=5
