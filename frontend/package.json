{
  "name": "@smap/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "fmt": "prettier --write .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "gen:api": "openapi --input ../backend/openapi.json --output src/shared/api-client --client axios --useOptions --useUnionTypes",
    "check:openapi-drift": "bash scripts/check-openapi-drift.sh",
    "check:bundle-size": "bash scripts/check-bundle-size.sh",
    "check:global-css": "bash scripts/check-global-css.sh",
    "check:view-tests": "bash scripts/check-view-tests.sh",
    "check:type-coverage": "bash scripts/check-type-coverage.sh",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "vue": "3.5.13",
    "vue-router": "4.4.5",
    "pinia": "2.2.6",
    "@tanstack/vue-query": "5.59.20",
    "axios": "1.15.0",
    "element-plus": "2.11.1",
    "@element-plus/icons-vue": "2.3.1",
    "vee-validate": "4.14.6",
    "@vee-validate/zod": "4.14.6",
    "zod": "3.23.8",
    "vue-i18n": "11.2.8",
    "@vue-flow/core": "1.42.1",
    "dompurify": "3.4.0",
    "markdown-it": "14.1.1",
    "highlight.js": "11.10.0",
    "katex": "0.16.21",
    "mermaid": "11.10.0"
  },
  "devDependencies": {
    "@types/dompurify": "3.2.0",
    "@types/markdown-it": "14.1.2",
    "@types/katex": "0.16.7",
    "@types/node": "20.17.10",
    "@vitejs/plugin-vue": "5.2.1",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.7.0",
    "eslint": "9.16.0",
    "eslint-plugin-vue": "9.32.0",
    "eslint-plugin-boundaries": "5.0.1",
    "@typescript-eslint/parser": "8.18.0",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "jsdom": "25.0.1",
    "openapi-typescript-codegen": "0.29.0",
    "typescript": "5.6.3",
    "unplugin-auto-import": "0.18.6",
    "unplugin-vue-components": "0.27.5",
    "vite": "6.4.2",
    "vite-plugin-checker": "0.8.0",
    "vitest": "2.1.9",
    "vue-tsc": "2.1.10",
    "eslint-plugin-vuejs-accessibility": "2.4.1",
    "type-coverage": "2.29.7",
    "msw": "2.7.3",
    "@playwright/test": "1.56.0",
    "@vitest/coverage-v8": "2.1.9"
  }
}
